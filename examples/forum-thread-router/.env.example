# Telegram bot token from @BotFather
BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrsTUVwxyz"

# Optional: a Telegram supergroup chat id (e.g. -1001234567890) where the bot will broadcast.
# Forum topics must be enabled on the group, and the bot must be an admin.
# When unset, the bot only responds inside the thread the user posts in.
BROADCAST_CHAT_ID=""

# Optional: comma-separated topic thread ids in that group, e.g. "2,5,12"
BROADCAST_THREAD_IDS=""
